{
  // Cloudflare Workers config for twochatbot.
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nicechat-bot",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],

  // Workers AI binding (fallback / backup AI provider). No extra resource needed.
  "ai": { "binding": "AI" },

  // KV namespace. Replace "id" with the id printed by: npm run kv:create
  "kv_namespaces": [
    { "binding": "TG_BOT_KV", "id": "39996f77e968492ea5b613ed008a08be" }
  ],

  // Non-sensitive config. Secrets (BOT_TOKEN / BOT_SECRET / AI_API_KEY) go via:
  //   wrangler secret put BOT_TOKEN
  "vars": {
    "ADMIN_UID": "8040798522",

    "RELAY_MODE": "private",        // private (enabled) | group (reserved, not enabled)
    "ADMIN_GROUP_ID": "",           // only for group mode; leave empty for now

    "AI_BASE_URL": "https://cliproxy.mtcacg.top/v1", // your relay station, OpenAI-compatible base url
    "AI_MODEL": "gpt-5.5",
    "AI_TIMEOUT_MS": "80000",
    "AI_PROVIDER": "relay",         // relay | workers_ai | auto
    "AI_FALLBACK_TO_CF": "true",
    "CF_AI_MODEL": "@cf/meta/llama-3.3-70b-instruct-fp8-fast",

    "FILTER_ENABLED": "true",
    "FILTER_THRESHOLD": "0.6",
    "BLOCK_KEYWORDS": "",

    "VERIFY_MODE": "math",          // math | quiz | turnstile(reserved)
    "VERIFY_QUESTION": "",
    "VERIFY_ANSWER": "",

    "WELCOME_MESSAGE": "喵～你好呀，这里是主人的专属双向小助手！为了挡住坏坏的广告机器人，请先回答一个超简单的小问题完成验证，然后就可以开始聊天啦～",
    "AUTO_GREETING": "喵～你好呀！我是主人的猫娘小助理，你的消息已经稳稳收到并转达给主人啦，请稍等主人回复你哦～(=^･ω･^=)",
    "AI_REPLY_PREVIEW": "preview",  // preview | send
    "AI_CONTEXT_ROUNDS": "6",

    "AUTO_SEARCH_ENABLED": "true",
    "SEARCH_PROVIDER": "brave",       // brave | tavily
    "SEARCH_MAX_RESULTS": "5",
    "SEARCH_DECISION_MODEL": ""       // empty = use current AI model
  }
}
