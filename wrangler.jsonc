{
  // Cloudflare Workers config for twochatbot.
  // Docs: https://developers.cloudflare.com/workers/wrangler/configuration/
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "twochatbot",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],

  // Workers AI binding (fallback / backup AI provider). No extra resource needed.
  "ai": { "binding": "AI" },

  // KV namespace. Replace "id" with the id printed by: npm run kv:create
  "kv_namespaces": [
    { "binding": "TG_BOT_KV", "id": "REPLACE_WITH_YOUR_KV_ID" }
  ],

  // Non-sensitive config. Secrets (BOT_TOKEN / BOT_SECRET / AI_API_KEY) go via:
  //   wrangler secret put BOT_TOKEN
  "vars": {
    "ADMIN_UID": "",

    "RELAY_MODE": "private",        // private (enabled) | group (reserved, not enabled)
    "ADMIN_GROUP_ID": "",           // only for group mode; leave empty for now

    "AI_BASE_URL": "",              // your relay station, OpenAI-compatible base url
    "AI_MODEL": "gpt-4o-mini",
    "AI_TIMEOUT_MS": "2500",
    "AI_PROVIDER": "auto",          // relay | workers_ai | auto
    "AI_FALLBACK_TO_CF": "true",
    "CF_AI_MODEL": "@cf/meta/llama-3.1-8b-instruct",

    "FILTER_ENABLED": "true",
    "FILTER_THRESHOLD": "0.6",
    "BLOCK_KEYWORDS": "",

    "VERIFY_MODE": "math",          // math | quiz | turnstile(reserved)
    "VERIFY_QUESTION": "",
    "VERIFY_ANSWER": "",

    "WELCOME_MESSAGE": "你好，我是这台双向机器人。请先通过一个简单验证再开始对话。",
    "AUTO_GREETING": "您好，这里是主人的助理，消息已转达，请稍候回复。",
    "AI_REPLY_PREVIEW": "preview",  // preview | send
    "AI_CONTEXT_ROUNDS": "6"
  }
}
